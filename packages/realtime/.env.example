# Realtime Collaboration Server Configuration

# WebSocket server port
PORT=3001

# Go backend API base URL
# This should match your backend server's address
GO_API_URL=http://localhost:8080/api/v1

# Whether realtime collaboration is enabled.
# Keep this in sync with packages/server/.env.
# When false, realtime will reject websocket auth and collaboration HTTP endpoints.
COLLABORATION_ENABLED=true

# JWT signing secret
# Must match the JWT_SECRET used in the Go backend
JWT_SECRET=your-secret-key-change-this-in-production
