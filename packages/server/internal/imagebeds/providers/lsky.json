{
  "providerType": "lsky",
  "displayName": "Lsky Pro",
  "description": "Lsky Pro (api/v2/upload)",
  "fields": [
    {
      "key": "baseUrl",
      "type": "url",
      "label": "Base URL",
      "labelKey": "user_image_beds_base_url_label",
      "placeholder": "https://img.example.com",
      "placeholderKey": "user_image_beds_base_url_placeholder",
      "helpText": "填写兰空站点地址，不要包含末尾的 /api/v2/upload",
      "helpTextKey": "user_image_beds_lsky_base_url_help",
      "inputMode": "url",
      "required": true
    },
    {
      "key": "apiToken",
      "type": "password",
      "label": "API Token",
      "labelKey": "user_image_beds_api_token_label",
      "placeholder": "Enter Lsky API token",
      "placeholderKey": "user_image_beds_api_token_placeholder",
      "helpText": "在兰空个人设置里创建 API Token",
      "helpTextKey": "user_image_beds_api_token_help",
      "inputMode": "text",
      "required": true
    },
    {
      "key": "storageId",
      "type": "number",
      "label": "Storage ID",
      "labelKey": "user_image_beds_storage_id_label",
      "placeholder": "1",
      "placeholderKey": "user_image_beds_storage_id_placeholder",
      "helpText": "必填，填写兰空存储策略对应的 storage_id",
      "helpTextKey": "user_image_beds_lsky_storage_id_help",
      "inputMode": "numeric",
      "required": true
    },
    {
      "key": "strategyId",
      "type": "text",
      "label": "Strategy ID",
      "labelKey": "user_image_beds_strategy_label",
      "placeholder": "Optional strategy id",
      "placeholderKey": "user_image_beds_strategy_placeholder",
      "helpText": "可选，留空则由图床使用默认策略",
      "helpTextKey": "user_image_beds_lsky_strategy_help",
      "inputMode": "text",
      "required": false
    }
  ],
  "runtime": {
    "defaultBaseUrl": "",
    "baseUrlEnv": "LSKY_API_URL",
    "apiTokenEnv": "LSKY_API_TOKEN"
  },
  "upload": {
    "method": "POST",
    "urlTemplate": "{{baseUrl}}/api/v2/upload",
    "fileField": "file",
    "headers": [
      {
        "key": "Authorization",
        "valueTemplate": "Bearer {{apiToken}}"
      },
      {
        "key": "Accept",
        "valueTemplate": "application/json"
      }
    ],
    "query": [],
    "formFields": [
      {
        "key": "storage_id",
        "valueTemplate": "{{storageId}}",
        "required": true,
        "omitIfEmpty": false
      },
      {
        "key": "strategy_id",
        "valueTemplate": "{{strategyId}}",
        "required": false,
        "omitIfEmpty": true
      }
    ],
    "successJsonPath": "status",
    "successEquals": "success",
    "resultUrlPaths": ["data.public_url", "data.url"],
    "errorMessagePaths": ["message"]
  }
}
