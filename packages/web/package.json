{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"machine-translate": "inlang machine translate --project project.inlang",
		"lint": "eslint . --ext .ts,.svelte",
		"lint:fix": "eslint . --ext .ts,.svelte --fix",
		"paraglide": "pnpm paraglide-js compile --project ./project.inlang",
		"paraglide:preview": "cp src/locales/en.json src/locales/en.json.bak && cp src/locales/zh.json src/locales/en.json && pnpm paraglide && mv src/locales/en.json.bak src/locales/en.json"
	},
	"devDependencies": {
		"@iconify-json/ph": "^1.2.2",
		"@inlang/cli": "^3.1.6",
		"@inlang/paraglide-js": "^2.13.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^25.3.5",
		"autoprefixer": "^10.4.27",
		"prosemirror-model": "^1.25.4",
		"prosemirror-view": "^1.41.6",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@milkdown/core": "^7.19.0",
		"@milkdown/crepe": "^7.19.0",
		"@milkdown/plugin-listener": "^7.19.0",
		"@milkdown/preset-gfm": "^7.19.0",
		"@milkdown/theme-nord": "^7.19.0",
		"@milkdown/utils": "^7.19.0",
		"phosphor-svelte": "^3.1.0",
		"svelte-sonner": "^1.0.8"
	}
}
